generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  role     Role   @default(EMPLOYEE)

  assignments         VesselAssignment[]
  activitiesCreated   Activity[]         @relation("ActivityCreatedBy")
  consumptionsCreated Consumption[]      @relation("ConsumptionCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vessel {
  id     Int     @id @default(autoincrement())
  code   String  @unique
  active Boolean @default(true)

  // ── ข้อมูลทั่วไป ───────────────────────────────
  name         String
  shortName    String? @db.VarChar(20)
  exName       String? @db.VarChar(100) // ชื่อเก่า เช่น EX. HBD 78
  type         String? @db.VarChar(50) // เช่น CONTAINER VESSEL
  owner        String? @db.VarChar(200)
  ownerAddress String? @db.VarChar(500)
  charterer    String? @db.VarChar(200) // ผู้เช่าเรือ

  // ── ข้อมูลทะเบียน ──────────────────────────────
  imoNumber      String?   @unique @db.VarChar(20)
  mmsi           String?   @db.VarChar(20)
  callSign       String?   @db.VarChar(20)
  registrationNo String?   @db.VarChar(50)
  flag           String?   @db.VarChar(50)
  portOfRegistry String?   @db.VarChar(100)
  classification String?   @db.VarChar(50) // เช่น TG, BV, LR
  yearBuilt      Int?
  lastDrydock    DateTime?

  // ── ขนาดเรือ ───────────────────────────────────
  loaMeters        Decimal? @db.Decimal(8, 3) // LOA (m)
  breadthMeters    Decimal? @db.Decimal(8, 3) // Breadth (m)
  depthMeters      Decimal? @db.Decimal(8, 3) // Depth (m)
  draftSummer      Decimal? @db.Decimal(8, 3) // Draft Summer (m)
  draftTropical    Decimal? @db.Decimal(8, 3) // Draft Tropical (m)
  draftTropicalFw  Decimal? @db.Decimal(8, 3) // Draft Tropical FW (m)
  draftAftFullLoad Decimal? @db.Decimal(8, 3) // Draft AFT at full load (m)
  fwa              Decimal? @db.Decimal(8, 3) // FWA (mm)
  lightShip        Decimal? @db.Decimal(10, 3) // Light Ship (MT)
  dwtSummer        Decimal? @db.Decimal(10, 3) // DWT Summer (MT)
  dwtTropical      Decimal? @db.Decimal(10, 3) // DWT Tropical (MT)
  tpc              Decimal? @db.Decimal(8, 3) // TPC (MT)

  // ── Tonnage ────────────────────────────────────
  grt Decimal? @db.Decimal(12, 2) // GRT (T)
  nrt Decimal? @db.Decimal(12, 2) // NRT (T)

  // ── Speed & Consumption ────────────────────────
  normalSpeed   Decimal? @db.Decimal(6, 2) // Normal speed (kts)
  normalFullRpm Decimal? @db.Decimal(8, 2) // Normal full RPM
  maximumSpeed  Decimal? @db.Decimal(6, 2) // Maximum speed (kts)
  maximumRpm    Decimal? @db.Decimal(8, 2) // Maximum RPM

  // ── Main Engine ────────────────────────────────
  mainEngineP       String?  @db.VarChar(200) // M/E (P) maker+model
  mainEnginePKw     Decimal? @db.Decimal(10, 2)
  mainEnginePCons   Decimal? @db.Decimal(8, 2) // L/HR at normal
  mainEngineS       String?  @db.VarChar(200) // M/E (S) maker+model
  mainEngineSKw     Decimal? @db.Decimal(10, 2)
  mainEngineSCons   Decimal? @db.Decimal(8, 2) // L/HR at normal
  mainEngineMaxCons Decimal? @db.Decimal(8, 2) // L/HR at MAX RPM

  // ── Generator ─────────────────────────────────
  generator1     String?  @db.VarChar(200) // maker+model
  generator1Kw   Decimal? @db.Decimal(8, 2)
  generator1Cons Decimal? @db.Decimal(8, 2) // L/HR
  generator2     String?  @db.VarChar(200)
  generator2Kw   Decimal? @db.Decimal(8, 2)
  generator2Cons Decimal? @db.Decimal(8, 2) // L/HR
  auxEngine      String?  @db.VarChar(200)

  // ── Tank Capacity ──────────────────────────────
  fuelBunkerTankCbm Decimal? @db.Decimal(10, 3) // CBM
  freshWaterTankCbm Decimal? @db.Decimal(10, 3) // CBM

  // ── Cargo Capacity ─────────────────────────────
  containerStowageTeu Int? // TEU ปัจจุบัน
  maxTeus             Int? // Max TEUs บรรทุกได้ 100%
  maxCargoCapacityMt  Decimal? @db.Decimal(10, 3) // MT ปัจจุบัน
  maxWeightMt         Decimal? @db.Decimal(10, 3) // Max Weight บรรทุกได้ 100% (MT)
  noOfCargoHold       Int?
  noOfRow             Int?
  reeferPoints        Int?
  dgApproved          Boolean? // DG Approved

  // ── Ship's Contact ─────────────────────────────
  contactEmail String? @db.VarChar(200)
  contactLine  String? @db.VarChar(100)
  contactPhone String? @db.VarChar(50)

  // ── Relations ──────────────────────────────────
  assignments VesselAssignment[]
  voyages     Voyage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VesselAssignment {
  id        Int      @id @default(autoincrement())
  userId    Int
  vesselId  Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  vessel Vessel @relation(fields: [vesselId], references: [id])

  @@unique([userId, vesselId])
  @@index([userId])
  @@index([vesselId])
}

model Voyage {
  id       Int          @id @default(autoincrement())
  vesselId Int
  voyNo    String
  startAt  DateTime
  endAt    DateTime?
  status   VoyageStatus @default(OPEN)
  active   Boolean      @default(true)

  fuelRob     FuelRob?
  fuelBunkers FuelBunkerEvent[]

  postingYear  Int
  postingMonth Int

  vessel     Vessel     @relation(fields: [vesselId], references: [id])
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vesselId, voyNo])
  @@index([vesselId])
  @@index([postingYear, postingMonth])
}

model Activity {
  id       Int          @id @default(autoincrement())
  voyageId Int
  type     ActivityType
  startAt  DateTime
  endAt    DateTime

  consumptions Consumption[]

  // เก็บปี/เดือนจาก startAt เพื่อ query ง่าย
  year  Int
  month Int

  // ✅ Common fields
  reeferCount Int?
  fuelUsed    Decimal? @db.Decimal(12, 2)

  // ✅ เครื่องไฟฟ้า 1/2 (Cargo, Anchoring, FSW, Manoeuvring)
  generator1Count Int?
  generator1Hours Decimal? @db.Decimal(10, 2)
  generator2Count Int?
  generator2Hours Decimal? @db.Decimal(10, 2)

  // ✅ Deckgen (Cargo, Anchoring)
  deckgenCount Int?
  deckgenHours Decimal? @db.Decimal(10, 2)

  // ✅ เครื่องจักรใหญ่ 1/2 (FSW, Manoeuvring)
  mainEngine1Count Int?
  mainEngine1Hours Decimal? @db.Decimal(10, 2)
  mainEngine2Count Int?
  mainEngine2Hours Decimal? @db.Decimal(10, 2)

  // ✅ ตู้ แยกขนาด (Cargo, Anchoring)
  container20Count     Int?
  container40Count     Int?
  totalContainerWeight Decimal? @db.Decimal(14, 3) // เฉพาะ Cargo

  // ✅ Draft (Cargo, Anchoring)
  draftFore String? @db.VarChar(20)
  draftAft  String? @db.VarChar(20)

  // ✅ ท่าเทียบ (Cargo เท่านั้น)
  berth    String? @db.VarChar(10) // "BKK" | "LCB"
  berthSub String? @db.VarChar(20) // เช่น "BMT", "KLN", "PA1"

  // ✅ สถานที่ทอดสมอ (Anchoring เท่านั้น)
  anchorLocation String? @db.VarChar(200)

  // ✅ Full speed away
  avgSpeed Decimal? @db.Decimal(10, 2) // หน่วย: นอต

  // ✅ กระแสน้ำ (FSW, Manoeuvring)
  currentDirection String? @db.VarChar(20) // "AGAINST" | "WITH"

  // ✅ ทิศทางลม (FSW เท่านั้น)
  windDirection String? @db.VarChar(10) // "N"|"NE"|"E"|"SE"|"S"|"SW"|"W"|"NW"

  // ✅ OTHER / หมายเหตุ
  remark String? @db.VarChar(500)

  active Boolean @default(true)

  createdById Int
  createdBy   User   @relation("ActivityCreatedBy", fields: [createdById], references: [id])
  voyage      Voyage @relation(fields: [voyageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([voyageId])
  @@index([year, month])
}

model Consumption {
  id         Int                 @id @default(autoincrement())
  activityId Int
  category   ConsumptionCategory
  itemName   String              @db.VarChar(100) // เช่น "MDO", "HFO", "Fresh Water", "Lube Oil"
  quantity   Decimal             @db.Decimal(14, 3)
  unit       ConsumptionUnit
  source     ConsumptionSource   @default(MANUAL)
  remark     String?             @db.VarChar(500)
  active     Boolean             @default(true)
  scope      ConsumptionScope    @default(OTHER)

  createdById Int
  createdBy   User     @relation("ConsumptionCreatedBy", fields: [createdById], references: [id])
  activity    Activity @relation(fields: [activityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activityId])
  @@index([category])
}

model FuelRob {
  id         Int      @id @default(autoincrement())
  voyageId   Int      @unique
  openingRob Decimal  @db.Decimal(14, 2)
  closingRob Decimal  @db.Decimal(14, 2)
  unit       String   @default("L")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  voyage Voyage @relation(fields: [voyageId], references: [id], onDelete: Cascade)
}

model FuelBunkerEvent {
  id        Int      @id @default(autoincrement())
  voyageId  Int
  at        DateTime
  amount    Decimal  @db.Decimal(14, 2)
  unit      String   @default("L")
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voyage Voyage @relation(fields: [voyageId], references: [id], onDelete: Cascade)

  @@index([voyageId, at])
}

enum ConsumptionScope {
  MAIN_ENGINE
  GENERATOR
  REEFER
  AUXILIARY
  OTHER
}

enum ConsumptionCategory {
  FUEL
  LUBE
  WATER
  OTHER
}

enum ConsumptionUnit {
  LITER
  KG
  TON
  KWH
  OTHER
}

enum ConsumptionSource {
  MANUAL
  CALCULATED
}

enum VoyageStatus {
  OPEN
  CLOSED
}

enum Role {
  EMPLOYEE
  SUPERVISOR
  MANAGER
  ADMIN
  CHARTERER
}

enum ActivityType {
  CARGO_LOAD
  MANOEUVRING
  FULL_SPEED_AWAY
  ANCHORING
  CARGO_DISCHARGE
  OTHER
}
